{
  "expo": {
    "name": "ZMK အဆောင်",
    "slug": "dormitory_rent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/home_rent_icon.png",
    "scheme": "dormitoryrent",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/home_rent_icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.chantoewhan.dormitory_rent"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c898afc9-5829-4df5-873a-c54603eac6b9"
      }
    }
  }
}
